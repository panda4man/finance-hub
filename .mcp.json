{
  "mcpServers": {
    "finance-hub": {
      "command": "node",
      "args": [
        "mcp/server.js"
      ]
    },
    "laravel-boost": {
      "command": "php",
      "args": [
        "artisan",
        "boost:mcp"
      ]
    },
    "bridge-api-guide": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/panda4man/the-bridge.git#subdirectory=bridge-mcp",
        "bridge-mcp"
      ],
      "env": {
        "BRIDGE_API_BASE_URL": "${BRIDGE_API_BASE_URL:-http://localhost:3000/api}",
        "BRIDGE_API_TOKEN": "${BRIDGE_API_TOKEN}"
      }
    }
  }
}
