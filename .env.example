APP_NAME="Finance Hub"
APP_ENV=production
# Stable secret, generated ONCE: `php artisan key:generate --show`
# Never rotate this post-deploy — it backs the `encrypted` cast on
# connections.credential_encrypted (stored SimpleFin credentials). Rotating
# APP_KEY makes existing encrypted credentials undecryptable.
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# --- Host port for the app container -----------------------------------
# Defaults to 3000 (the port the old NestJS app used) if unset. Set
# explicitly if 3000 is already taken by something else on this host.
LARAVEL_APP_PORT=3000

# --- Database ------------------------------------------------------------
# Laravel reads DB_*; the postgres container reads POSTGRES_* — keep both
# pairs in sync (same split as the root NestJS app's .env.example).
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=finance_hub
DB_USERNAME=finance
DB_PASSWORD=CHANGE_ME

POSTGRES_USER=finance
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=finance_hub

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# --- SimpleFin sync (see config/finance.php) -----------------------------
SYNC_ENABLED=true
SYNC_CRON="0 4 * * *"
FINANCE_SYNC_QUEUE=finance-sync
SYNC_OVERLAP_DAYS=4
BACKFILL_WINDOW_DAYS=90
BACKFILL_EMPTY_WINDOWS_TO_STOP=3
BACKFILL_MAX_WINDOWS=200
STALE_SYNC_THRESHOLD_HOURS=24

# Set to 1 only on the app service — docker-compose.yml does this
# automatically for `app` (one-shot migrate + seed on boot). Do not set
# this globally in .env, or the queue/scheduler containers will also try
# to run migrations on every restart.
RUN_MIGRATIONS=0

# the-bridge deploy (see .claude/skills/the-bridge-deploy/SKILL.md)
BRIDGE_APP_ID=17

VITE_APP_NAME="${APP_NAME}"
