NODE_ENV=production
TZ=America/New_York
PORT=3000

DATABASE_URL=postgres://finance:CHANGE_ME@postgres:5432/finance_hub
POSTGRES_USER=finance
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=finance_hub

# Optional here — can instead be set post-boot via `npm run configure`'s
# printed /setup URL (persisted encrypted in the DB, takes effect with no restart).
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_COUNTRY_CODES=US
PLAID_LANGUAGE=en
PLAID_REDIRECT_URI=
PLAID_WEBHOOK_URL=

# Hostname `npm run configure` prints in the /setup URL (cosmetic only)
PUBLIC_HOST=localhost

# openssl rand -base64 32
ENCRYPTION_KEY=
# openssl rand -hex 32
INTERNAL_API_TOKEN=

SYNC_ENABLED=true
SYNC_CRON="0 3 * * *"

# the-bridge deploy (see .claude/skills/the-bridge-deploy/SKILL.md)
BRIDGE_APP_ID=
BRIDGE_API_TOKEN=
